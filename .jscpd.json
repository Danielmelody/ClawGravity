{
    "threshold": 5,
    "reporters": [
        "html",
        "console"
    ],
    "ignore": [
        "node_modules",
        "dist",
        "build",
        "coverage",
        ".git",
        "**/*.test.ts",
        "**/*.spec.ts",
        "locales"
    ],
    "absolute": false,
    "gitignore": true,
    "format": [
        "typescript",
        "javascript"
    ],
    "minLines": 5,
    "minTokens": 50,
    "output": "report/jscpd"
}