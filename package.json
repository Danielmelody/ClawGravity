{
  "name": "claw-gravity",
  "version": "0.3.0",
  "description": "ClawGravity — An OpenClaw implementation built on Antigravity's Agent capabilities. More stable, more token-efficient, all-in-one. Control Antigravity remotely via Discord + Telegram.",
  "main": "dist/index.js",
  "bin": {
    "claw-gravity": "dist/bin/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:integration": "jest tests/e2e.bot.test.ts",
    "test:watch": "jest --watch",
    "build": "tsc",
    "start": "npm run check && npm run build && node dist/bin/cli.js",
    "start:built": "node dist/bin/cli.js",
    "dev": "ts-node-dev --respawn src/bin/cli.ts",
    "docs:diagram": "mmdc -i docs/diagrams/architecture.mmd -o docs/images/architecture.svg -b transparent",
    "cpd": "jscpd src/",
    "dead-code": "knip",
    "check": "npm run dead-code && npm run cpd && tsc --noEmit && eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "discord",
    "bot",
    "ai",
    "antigravity",
    "openclaw",
    "remote-control"
  ],
  "author": "ClawGravity Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Danielmelody/ClawGravity.git"
  },
  "bugs": {
    "url": "https://github.com/Danielmelody/ClawGravity/issues"
  },
  "homepage": "https://github.com/Danielmelody/ClawGravity#readme",
  "dependencies": {
    "@inquirer/select": "^4.4.2",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "grammy": "^1.41.1",
    "marked": "^15.0.12",
    "node-cron": "^4.2.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/marked": "^5.0.2",
    "@types/node": "^25.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "eslint": "^10.0.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.2.0",
    "jscpd": "^4.0.8",
    "knip": "^5.86.0",
    "semantic-release": "^25.0.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
