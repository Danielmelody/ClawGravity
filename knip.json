{
    "$schema": "https://unpkg.com/knip@latest/schema.json",
    "project": [
        "src/**/*.ts",
        "tests/**/*.ts"
    ],
    "ignoreBinaries": [
        "ts-node-dev"
    ],
    "ignoreDependencies": [
        "@types/marked",
        "ts-node-dev"
    ],
    "rules": {
        "types": "warn"
    }
}